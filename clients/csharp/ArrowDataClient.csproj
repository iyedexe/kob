<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>ArrowDataClient</RootNamespace>
    <AssemblyName>arrow-data-client</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Core Arrow: IPC stream reader (zero-copy into typed columns). -->
    <PackageReference Include="Apache.Arrow" Version="23.0.0" />
    <!-- REQUIRED for LZ4/ZSTD IPC buffer compression — NOT in core Apache.Arrow. -->
    <PackageReference Include="Apache.Arrow.Compression" Version="23.0.0" />
    <!-- Arrow Flight client (gRPC). Pulls in Grpc.Net.Client transitively. -->
    <PackageReference Include="Apache.Arrow.Flight" Version="23.0.0" />
    <PackageReference Include="Grpc.Net.Client" Version="2.71.0" />
  </ItemGroup>

</Project>
